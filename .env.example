# ============================================================================
# Klushulpgids.nl — Environment variables
#
# Voor lokale ontwikkeling: kopieer naar `.env.local` en vul in.
# In productie: zet via `scalingo --app klushulpgids env-set KEY=value`.
# Variabelen zonder waarde hieronder worden pas in latere fases ingevuld.
# ============================================================================

# ---------- Auto-set door Scalingo addons ----------
DATABASE_URL=
REDIS_URL=

# ---------- NextAuth (fase 6) ----------
NEXTAUTH_URL=https://klushulpgids.nl
NEXTAUTH_SECRET=

# ---------- Lettermint (fase 6) ----------
LETTERMINT_API_KEY=
FROM_EMAIL=noreply@klushulpgids.nl

# ---------- Object Storage (fase 6 — alleen invullen wanneer foto-uploads aan) ----------
# Provider-agnostic: werkt met Scaleway, Exoscale, OVHcloud, etc.
# Voorbeeld voor Scaleway: STORAGE_ENDPOINT=https://s3.fr-par.scw.cloud
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=klushulpgids-photos
STORAGE_REGION=
STORAGE_ENDPOINT=

# ---------- Plausible (cookieless analytics) ----------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=klushulpgids.nl

# ---------- Sentry (optioneel, post-launch — laat leeg voor MVP) ----------
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ---------- SEO verification (fase 5) ----------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ---------- Encryptie (fase 2) ----------
# 32+ tekens random; gebruik `openssl rand -hex 32`
ENCRYPTION_KEY=

# ---------- Revalidation ----------
REVALIDATE_SECRET=

# ---------- Feature flags (fase 8) — alles false bij launch ----------
NEXT_PUBLIC_FEATURE_PREMIUM_LISTINGS=false
NEXT_PUBLIC_FEATURE_SPONSORED=false
NEXT_PUBLIC_FEATURE_DISPLAY_ADS=false
NEXT_PUBLIC_FEATURE_PAYMENTS=false
NEXT_PUBLIC_FEATURE_COMPARE=false
NEXT_PUBLIC_FEATURE_ADV_ANALYTICS=false

# ---------- Mollie (fase 8) ----------
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=
